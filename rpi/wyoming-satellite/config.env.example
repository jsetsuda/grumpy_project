# Grumpy Wyoming Satellite configuration
# Generated by setup.sh. Values after '=' are shell-safe literals (no quotes needed).

# ── Identity ─────────────────────────────────────────────────────────────────
# Unique name HA uses to identify this satellite. Convention: pi-<room>.
# This becomes the assist_satellite.grumpy_<slug> entity in HA.
DEVICE_NAME=pi-unnamed

# ── Audio devices (ALSA) ─────────────────────────────────────────────────────
# Populated by setup.sh autodetect. Override here if you swap hardware.
# Run `arecord -L` and `aplay -L` to see available devices.
MIC_DEVICE=default
SPEAKER_DEVICE=default

# Sample rates — 16 kHz for mic is what Whisper expects; 22.05 kHz for
# output matches Piper's default synthesis. Usually leave alone.
MIC_RATE=16000
SPEAKER_RATE=22050

# ── Wake word ────────────────────────────────────────────────────────────────
# Points at the openWakeWord Wyoming service on the Backend VM. The Pi offloads
# wake detection to conserve CPU.
WAKE_HOST=192.168.5.118
WAKE_PORT=10400

# Stock models available today: ok_nabu, hey_jarvis, hey_mycroft, alexa.
# Change to `hey_grumpy` once that custom model is trained and dropped into
# backend/data/openwakeword/ on the Backend VM.
WAKE_WORD_NAME=ok_nabu

# ── Network ──────────────────────────────────────────────────────────────────
# Port HA will connect to for this satellite. Rarely changed.
SATELLITE_PORT=10700
