# Grumpy Kiosk — Raspberry Pi configuration
# Copy to `.env` and adjust for your setup.
#
# The Pi is a thin client — it just runs Chromium pointed at the
# backend VM's dashboard server. No credentials needed here.

# URL of the dashboard server running on the backend VM
DASHBOARD_URL=https://192.168.5.118:5173

# Device name — used to assign a specific dashboard to this Pi
# Set this in Dashboard Manager → Device Assignments
DEVICE_NAME=pi-kitchen

# X11 display (default :0, usually don't need to change)
DISPLAY=:0
