# /etc/raspotify/conf — generated by setup.sh
#
# Reference of the most useful knobs. The installer writes a populated
# version of this file. Restart raspotify after editing:
#   sudo systemctl restart raspotify

# What shows up in Spotify's device picker.
LIBRESPOT_NAME=Grumpy (pi-host)

# Audio quality: 96, 160, or 320 kbps. 320 needs Premium.
LIBRESPOT_BITRATE=320

# Output backend. With PipeWire (default on modern Pi OS desktops and
# what linux-voice-assistant uses), keep `pulseaudio` — PipeWire ships
# a PulseAudio shim. Use `alsa` only if PipeWire is not running.
LIBRESPOT_BACKEND=pulseaudio

# Specific output device. Blank = default. Run `pactl list short sinks`
# (PipeWire/PA) or `aplay -L` (ALSA) to see options.
# LIBRESPOT_DEVICE=

# Volume on first connect (0-100). Spotify clients can override.
LIBRESPOT_INITIAL_VOLUME=80

# Smooth out volume differences between tracks.
LIBRESPOT_VOLUME_NORMALISATION=true

# Allow other Spotify clients to take over playback without
# disconnecting first.
LIBRESPOT_AUTOPLAY=on

# Disable dithering — needed if you hear audio glitches on PulseAudio.
# LIBRESPOT_DITHER=none
