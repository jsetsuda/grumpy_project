# Grumpy Dashboard — environment configuration
# Copy to `.env` and fill in your values.

# ---- Home Assistant ----
VITE_HA_URL=http://homeassistant.local:8123
VITE_HA_TOKEN=your-long-lived-access-token-here

# ---- Weather Widget ----
# Default coordinates (Detroit area). Override per-widget in the config.
VITE_DEFAULT_LAT=42.3314
VITE_DEFAULT_LON=-83.0458
