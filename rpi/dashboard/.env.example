# Grumpy Dashboard Server — environment configuration
# Copy to `.env` and adjust as needed.
#
# This runs on the BACKEND VM, not the Raspberry Pi.
# All service credentials (HA, Spotify, Google, etc.) are managed
# centrally via the Dashboard Manager at /manage → Shared Credentials.

# ---- Server ----
# Port the dashboard server listens on
PORT=5173

# Enable HTTPS with auto-generated self-signed certificate
# Set to "false" if running behind a reverse proxy that handles TLS
TLS=true

# ---- Timezone ----
TZ=America/Detroit
