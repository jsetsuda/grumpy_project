# Grumpy backend — environment configuration
# Copy to `.env` and tune. `.env` is gitignored.

# ---- General ----
TZ=America/Detroit

# ---- Whisper (STT) — runs on the RTX 3090 ----
# Model selection:
#   medium-int8  : ~750MB VRAM,  fast, good accuracy
#   large-v3     : ~4GB VRAM,    best accuracy            <-- recommended
#   large-v3-turbo : ~4GB VRAM,  nearly as accurate, faster
WHISPER_MODEL=large-v3
WHISPER_LANG=en
WHISPER_BEAM=1

# ---- Piper (TTS) ----
# Voice samples: https://rhasspy.github.io/piper-samples/
#   en_US-lessac-medium   : neutral female, clear         <-- default
#   en_US-ryan-medium     : neutral male
#   en_US-amy-medium      : warmer female
#   en_GB-alba-medium     : British female
PIPER_VOICE=en_US-lessac-medium

# ---- openWakeWord ----
# Built-in models:
#   ok_nabu         : "Okay Nabu"                         <-- HA's default
#   hey_jarvis      : "Hey Jarvis"
#   hey_mycroft     : "Hey Mycroft"
#   alexa           : AVOID — triggers real Alexa devices
#
# A custom "Hey Grumpy" model can be trained and placed in
# ./data/openwakeword/ (Phase 2.5).
WAKE_WORD=ok_nabu
WAKE_THRESHOLD=0.5
